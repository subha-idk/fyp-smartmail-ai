# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5433/smartmail
REDIS_URL=redis://localhost:6379/0

# Auth
API_SECRET_KEY=your-secret-key-here

# Gemini API
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash
LLM_MAX_TOKENS=1000
LLM_MONTHLY_TOKEN_BUDGET=5000000

# Email
EMAIL_PROVIDER=smtp
SENDGRID_API_KEY=SG...
SMTP_HOST=localhost
SMTP_PORT=1025

# ML thresholds (tunable)
CHURN_RISK_THRESHOLD=0.7
PURCHASE_PROB_THRESHOLD=0.6
TOP_SPENDER_THRESHOLD=500.0
CART_ABANDON_HOURS=24
EMAIL_COOLDOWN_HOURS=24

# App
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
DEBUG=true

# Frontend (exposed to browser)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=your-secret-key-here
